{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Default Renovate presets",
  "extends": [
    "config:base",
    ":disableDependencyDashboard",
    ":prHourlyLimitNone"
  ],
  "prConcurrentLimit": 2,
  "addLabels": ["dependencies"],
  "internalChecksFilter": "strict",
  "rebaseWhen": "conflicted",
  "packageRules": [
    {
      "description": "Limit major version updates",
      "matchUpdateTypes": ["major", "patch"],
      "enabled": false
    },
    {
      "description": "Add the github-actions label to Github Actions PRs",
      "matchManagers": ["github-actions"],
      "addLabels": ["github-actions"]
    },
    {
      "description": "Group minor GitHub Action updates",
      "matchManagers": ["github-actions"],
      "groupName": "CI dependencies",
      "groupSlug": "ci-deps",
      "matchUpdateTypes": ["major"]
    }
  ],
  "automerge": false,
  "platformAutomerge": false
}
